---
import '../styles/account.css';
---
<!doctype html>
<html lang="nl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Account — CMD Casino</title>
  </head>
  <body>
    <div class="card" id="account-card">
      <div class="profile-header">
        <div class="avatar" id="avatar-initials">–</div>
        <h2 id="user-name">–</h2>
      </div>
      <div class="stats">
        <div class="stat-row">
          <span class="stat-label">EC-Punten</span>
          <span class="stat-value coins" id="user-coins">–</span>
        </div>
        <div class="stat-row">
          <span class="stat-label">Lid sinds</span>
          <span class="stat-value" id="user-created">–</span>
        </div>
      </div>
      <div class="actions">
        <a href="/shop" class="btn btn-primary">EC-Punten kopen</a>
        <a href="/" class="btn btn-secondary">Spelen</a>
      </div>
      <a href="/vakken" class="btn btn-reward" style="display:block;text-align:center;text-decoration:none;margin-bottom:10px;">Vakken bekijken</a>
      <button class="btn btn-reward" id="reward-btn">Dagelijkse beloning (+1 EC-Punten)</button>
      <p id="reward-msg"></p>
      <button class="btn btn-logout" id="logout-btn">Uitloggen</button>
    </div>
    <div id="not-logged" class="card" style="display:none">
      <p>Niet ingelogd. <a href="/login">Inloggen</a> of <a href="/signup">registreren</a>.</p>
    </div>
    <script src="../scripts/account.js"></script>
  </body>
</html>
