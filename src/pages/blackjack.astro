---
import '../styles/blackjack.css';
---
<!doctype html>
<html lang="nl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Blackjack</title>
  </head>
  <body>
    <main class="bj-stage">

      <header class="bj-header">
        <div class="header-left">
          <a href="/" class="back-link">← Lobby</a>
        </div>
        <div class="header-center">
          <span class="bank-display"><strong id="bank">–</strong></span>
        </div>
        <div class="header-right">
          <button id="muteBtn" class="mute-btn" aria-pressed="false" title="Geluid aan/uit">🔊</button>
          <a href="/account" class="account-link">Account</a>
        </div>
      </header>

      <div class="bj-table">

        <!-- Dealer zone -->
        <div class="zone dealer-zone">
          <div class="zone-label">Dealer</div>
          <div id="dealerHand" class="hand"></div>
          <div class="score-badge" id="dealerScoreBadge">
            <span id="dealerScore">–</span>
          </div>
        </div>

        <!-- Center divider / message -->
        <div class="table-center">
          <div class="table-ring"></div>
          <div id="message" class="outcome-msg"></div>
        </div>

        <!-- Player zone -->
        <div class="zone player-zone">
          <div class="player-hands">
            <div class="player-hand-col" id="playerHandCol">
              <div class="score-badge" id="playerScoreBadge">
                <span id="playerScore">0</span>
              </div>
              <div id="playerHand" class="hand"></div>
            </div>
            <div class="player-hand-col" id="splitHandWrap" style="display:none">
              <div class="score-badge" id="splitScoreBadge">
                <span id="splitScore">0</span>
              </div>
              <div id="splitHand" class="hand"></div>
            </div>
          </div>
          <div class="zone-label">Jij</div>
        </div>

      </div>

      <!-- Controls -->
      <div class="controls-panel">
        <div class="bet-section">
          <label class="bet-label" for="betAmount">Inzet</label>
          <div class="bet-input-row">
            <button class="chip-btn" data-set="1">1</button>
            <button class="chip-btn" data-set="3">3</button>
            <button class="chip-btn" data-set="5">5</button>
            <button class="chip-btn" data-set="10">10</button>
            <input id="betAmount" type="number" value="1" min="1" />
          </div>
        </div>
        <div class="action-row">
          <button id="newBtn" class="btn-action btn-new">↺</button>
          <button id="dealBtn" class="btn-action btn-deal" disabled>Deal</button>
          <button id="hitBtn" class="btn-action btn-hit" disabled>Hit</button>
          <button id="standBtn" class="btn-action btn-stand" disabled>Stand</button>
          <button id="doubleBtn" class="btn-action btn-double" disabled>2×</button>
          <button id="splitBtn" class="btn-action btn-split" disabled>Split</button>
        </div>
      </div>

    </main>

    <script src="../scripts/auth-client.js"></script>
    <script src="../scripts/sound.js"></script>
    <script src="../scripts/blackjack.js"></script>
    <!-- <script is:inline>
      async function navigateAfterSave(href) {
        if (window.pendingSave) await window.pendingSave;
        location.href = href;
      }
      document.querySelector('.back-link').addEventListener('click', (e) => {
        e.preventDefault();
        navigateAfterSave(e.currentTarget.href);
      });
      document.querySelector('.account-link').addEventListener('click', (e) => {
        e.preventDefault();
        navigateAfterSave(e.currentTarget.href);
      });
    </script> -->
  </body>
</html>
