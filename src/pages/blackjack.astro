---
<!doctype html>
<html lang="nl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Blackjack</title>
    <link rel="stylesheet" href="/blackjack.css">
  </head>
  <body>
    <main class="bj-stage">
      <header class="bj-header">
        <div class="header-left">
          <a href="/" class="back-link">← Lobby</a>
        </div>
        <div class="header-right">
          <span>Bank: <strong id="bank">–</strong></span>
          <a href="/account" class="account-link">Account</a>
        </div>
      </header>

      <div class="phase-bar">
        <span id="message" class="message"></span>
      </div>

      <section class="table">
        <div class="area dealer-area">
          <div class="label">Dealer</div>
          <div id="dealerHand" class="hand"></div>
          <div class="score">Score: <span id="dealerScore">–</span></div>
        </div>

        <div class="area player-area">
          <div class="label">You</div>
          <div id="playerHand" class="hand"></div>
          <div class="score">Score: <span id="playerScore">0</span></div>
        </div>
      </section>

      <section id="controls" class="controls">
        <div class="bet-row">
          <label for="betAmount">Bet:</label>
          <input id="betAmount" type="number" value="50" min="1" />
        </div>
        <div class="btn-row">
          <button id="dealBtn" disabled>Deal</button>
          <button id="hitBtn" disabled>Hit</button>
          <button id="standBtn" disabled>Stand</button>
          <button id="newBtn">New Game</button>
        </div>
      </section>
    </main>

    <script is:inline type="module" src="/auth-client.js"></script>
    <script is:inline src="/blackjack.js"></script>
    <script is:inline>
      async function navigateAfterSave(href) {
        if (window.pendingSave) await window.pendingSave;
        location.href = href;
      }
      document.querySelector('.back-link').addEventListener('click', (e) => {
        e.preventDefault();
        navigateAfterSave(e.currentTarget.href);
      });
      document.querySelector('.account-link').addEventListener('click', (e) => {
        e.preventDefault();
        navigateAfterSave(e.currentTarget.href);
      });
    </script>
  </body>
</html>
