<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Blackjack</title>
    <link rel="stylesheet" href="/blackjack.css">
  </head>
  <body>
    <main class="bj-stage">
      <header class="bj-header">
        <h1>Blackjack</h1>
        <div class="balance">Bank: $<span id="bank">1000</span></div>
      </header>

      <section class="table">
        <div class="dealer area">
          <div class="label">Dealer</div>
          <div id="dealerHand" class="hand"></div>
          <div class="score">Score: <span id="dealerScore">-</span></div>
        </div>

        <div class="player area">
          <div class="label">You</div>
          <div id="playerHand" class="hand"></div>
          <div class="score">Score: <span id="playerScore">0</span></div>
        </div>
      </section>

      <aside style="margin-top:16px;">
        <h3>Players at table</h3>
        <div id="playerList">(none yet)</div>
      </aside>

      <section class="controls">
        <div class="bet">
          <label>Bet: $<input id="betAmount" type="number" min="1" value="50"></label>
          <button id="dealBtn">Deal</button>
        </div>
        <div class="actions">
          <button id="hitBtn" disabled>Hit</button>
          <button id="standBtn" disabled>Stand</button>
          <button id="newBtn">New Hand</button>
        </div>
        <div class="message" id="message"></div>
      </section>
    </main>

      <script>
        // expose URL params to blackjack.js
        const _BJ_PARAMS = (function(){
          const p = new URLSearchParams(location.search);
          return { room: p.get('room') || '', name: p.get('name') || '', host: p.get('host') === '1' };
        })();
        // show player name and room in header if present
        (function(){
          const params = _BJ_PARAMS;
          if(params && params.name){
            const label = document.createElement('div'); label.className = 'player-label';
            label.textContent = 'Player: ' + params.name + (params.host ? ' (host)' : '');
            const header = document.querySelector('.bj-header'); if(header) header.appendChild(label);
          }
        })();
      </script>

      <script type="module" src="/blackjack.js"></script>
  </body>
</html>
