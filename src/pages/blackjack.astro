<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Blackjack</title>
    <link rel="stylesheet" href="/blackjack.css">
  </head>
  <body>
    <main class="bj-stage">
      <header class="bj-header">
        <h1>Blackjack</h1>
        <div class="balance">Bank: $<span id="bank">1000</span></div>
      </header>

      <section class="table">
        <div class="dealer area">
          <div class="label">Dealer</div>
          <div id="dealerHand" class="hand"></div>
          <div class="score">Score: <span id="dealerScore">-</span></div>
        </div>

        <div class="player area">
          <div class="label">You</div>
          <div id="playerHand" class="hand"></div>
          <div class="score">Score: <span id="playerScore">0</span></div>
        </div>
      </section>

      <section class="controls">
        <div class="bet">
          <label>Bet: $<input id="betAmount" type="number" min="1" value="50"></label>
          <button id="dealBtn">Deal</button>
        </div>
        <div class="actions">
          <button id="hitBtn" disabled>Hit</button>
          <button id="standBtn" disabled>Stand</button>
          <button id="newBtn">New Hand</button>
        </div>
        <div class="message" id="message"></div>
      </section>
    </main>

    <script type="module" src="/blackjack.js"></script>
  </body>
</html>
