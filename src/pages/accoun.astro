<!doctype html>
<html lang="nl">
  <head>
    <meta charset="utf-8" />
    <title>Account — Blackjack</title>
    <link rel="stylesheet" href="/index.css" />
    <style>
      body { display:flex; align-items:center; justify-content:center; min-height:100vh; margin:0; background:#1a1a2e; }
      .card { background:#16213e; border:1px solid #0f3460; border-radius:16px; padding:36px 40px; width:100%; max-width:420px; box-shadow:0 8px 32px rgba(0,0,0,0.4); }
      h2 { margin:0 0 24px 0; color:#e2e2e2; font-size:24px; text-align:center; }
      .row { display:flex; justify-content:space-between; padding:12px 0; border-bottom:1px solid #0f3460; color:#ccc; font-size:15px; }
      .balance { font-size:22px; font-weight:700; color:#ffd700; }
      .actions { margin-top:24px; display:flex; gap:12px; }
      .btn { flex:1; padding:11px; border-radius:8px; border:0; font-size:14px; font-weight:600; cursor:pointer; text-align:center; text-decoration:none; display:inline-block; }
      .btn-primary { background:#e94560; color:#fff; }
      .btn-secondary { background:#0f3460; color:#e2e2e2; }
      .btn-logout { background:transparent; border:1px solid #e94560; color:#e94560; }
      #not-logged-in { display:none; text-align:center; color:#aaa; }
      #not-logged-in a { color:#e94560; }
    </style>
  </head>
  <body>
    <div class="card" id="account-card" style="display:none">
      <h2>Mijn Account</h2>
      <div class="row"><span>E-mail</span><strong id="user-email">—</strong></div>
      <div class="row"><span>Coins</span><span class="balance" id="user-coins">—</span></div>
      <div class="row"><span>Lid sinds</span><strong id="user-created">—</strong></div>
      <div class="actions">
        <a href="/shop" class="btn btn-primary">Coins kopen</a>
        <a href="/" class="btn btn-secondary">Spelen</a>
      </div>
      <div class="actions">
        <button class="btn btn-logout" id="logout-btn">Uitloggen</button>
      </div>
    </div>
    <div id="not-logged-in">
      <p>Niet ingelogd. <a href="/login">Inloggen</a> of <a href="/signup">registreren</a>.</p>
    </div>
    <script>
      async function loadAccount() {
        const token = localStorage.getItem('token');
        if (!token) { document.getElementById('not-logged-in').style.display = 'block'; return; }
        const [meRes, balRes] = await Promise.all([
          fetch('/api/me', { headers: { Authorization: 'Bearer ' + token }, credentials: 'include' }),
          fetch('/api/balance.json', { headers: { Authorization: 'Bearer ' + token }, credentials: 'include' }),
        ]);
        if (!meRes.ok) { localStorage.removeItem('token'); document.getElementById('not-logged-in').style.display = 'block'; return; }
        const me = await meRes.json();
        const bal = balRes.ok ? await balRes.json() : { balance: 0 };
        document.getElementById('user-email').textContent = me.email;
        document.getElementById('user-coins').textContent = (bal.balance ?? 0).toLocaleString('nl-NL') + ' 🪙';
        document.getElementById('user-created').textContent = me.createdAt ? new Date(me.createdAt).toLocaleDateString('nl-NL') : '—';
        document.getElementById('account-card').style.display = 'block';
      }
      document.getElementById('logout-btn').addEventListener('click', () => {
        localStorage.removeItem('token');
        document.cookie = 'session=; Path=/; Max-Age=0';
        location.href = '/login';
      });
      loadAccount();
    </script>
  </body>
</html>
