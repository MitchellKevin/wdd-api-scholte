---
import '../styles/blackjack.css';
import '../styles/mines.css';
---
<!doctype html>
<html lang="nl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Mines</title>
  </head>
  <body>
    <main class="bj-stage">

      <header class="bj-header">
        <div class="header-left">
          <a href="/" class="back-link">← Lobby</a>
        </div>
        <div class="header-center">
          <span class="game-title-badge">Mines</span>
          <span class="bank-display"><strong id="bank">–</strong></span>
        </div>
        <div class="header-right">
          <button id="muteBtn" class="mute-btn" aria-pressed="false" title="Geluid aan/uit">🔊</button>
          <a href="/account" class="account-link">Account</a>
        </div>
      </header>

      <!-- Multiplier bar (shown during game) -->
      <div id="multiplierBar" class="multiplier-bar" style="display:none">
        <span class="mult-label">Multiplier</span>
        <span id="multiplierValue" class="mult-value">1.00×</span>
        <span id="winPreview" class="mult-preview">= 0 EC</span>
      </div>

      <!-- Grid -->
      <div class="mines-area">
        <div id="minesGrid" class="mines-grid"></div>
      </div>

      <!-- Controls -->
      <div class="controls-panel">

        <!-- Setup phase -->
        <div id="ctrlSetup" class="ctrl-section">
          <div class="setup-row">
            <div class="bet-section">
              <label class="bet-label" for="betAmount">Inzet</label>
              <div class="bet-input-row">
                <button class="chip-btn" data-bet="1">1</button>
                <button class="chip-btn" data-bet="5">5</button>
                <button class="chip-btn" data-bet="10">10</button>
                <button class="chip-btn" data-bet="25">25</button>
                <input id="betAmount" type="number" value="1" min="1" />
              </div>
            </div>
            <div class="mines-section">
              <label class="bet-label">Mijnen</label>
              <div class="mines-select-row">
                <button class="mine-btn" data-mines="1">1</button>
                <button class="mine-btn active" data-mines="3">3</button>
                <button class="mine-btn" data-mines="5">5</button>
                <button class="mine-btn" data-mines="10">10</button>
                <button class="mine-btn" data-mines="24">24</button>
              </div>
            </div>
          </div>
          <div class="action-row">
            <button id="startBtn" class="btn-action btn-deal">Spel Starten</button>
          </div>
        </div>

        <!-- In-game phase -->
        <div id="ctrlGame" class="ctrl-section" style="display:none">
          <div class="action-row">
            <button id="cashoutBtn" class="btn-action btn-cashout">
              Uitbetalen: <span id="cashoutAmount">0</span> EC
            </button>
          </div>
          <p id="gameMsg" class="wait-msg"></p>
        </div>

        <div id="errorMsg" class="error-msg" style="display:none"></div>

      </div>
    </main>

    <script src="../scripts/sound.js"></script>
    <script src="../scripts/mines.js"></script>
  </body>
</html>
