---
---
<!doctype html>
<html lang="nl">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>Blackjack</title>
    <link rel="stylesheet" href="/index.css" />
    <style>
	h1{
		background: linear-gradient(135deg, #fff 0%, #d2d215 80%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
		font-size: 1.5em;
	}	
	  
      .lobby {
        display: flex;
        flex-direction: column;
        align-items: center;
		justify-content: center;
        gap: 20px;
		height: 100vh;
        padding: 80px 24px;
        position: relative;
        z-index: 1;
      }
      .user-bar {
        color: rgba(255,255,255,0.4);
        font-size: 14px;
        display: flex;
        align-items: center;
        gap: 6px;
      }
      .user-bar strong { color: #d2d215; font-weight: 700; }
      .divider { color: rgba(255,255,255,0.15); }
      .room-form {
        display: flex;
		flex-direction: column;
        gap: 10px;
        width: 100%;
        max-width: 360px;
      }
      .room-form input {
        flex: 1;
        padding: 12px 16px;
        border-radius: 12px;
        border: 1px solid rgba(255,255,255,0.1);
        background: rgba(255,255,255,0.06);
        backdrop-filter: blur(8px);
        color: rgba(255,255,255,0.85);
        font-size: 16px;
        font-family: inherit;
        text-align: center;
        transition: border-color 0.15s, box-shadow 0.15s;
      }
      .room-form input:focus { outline: none; border-color: rgba(233,69,96,0.5); box-shadow: 0 0 0 3px rgba(233,69,96,0.1); }
      .room-form input::placeholder { color: rgba(255,255,255,0.2); }
      .btn {
        padding: 12px 20px;
        border-radius: 12px;
        border: none;
        font-size: 14px;
        font-weight: 700;
        font-family: inherit;
        cursor: pointer;
        transition: opacity 0.15s, transform 0.1s;
        white-space: nowrap;
      }
      .btn:hover { opacity: 0.9; transform: translateY(-1px); }
      .btn:active { transform: translateY(0); }
      .btn-join {
        background: linear-gradient(135deg, #2d8b5b, #1f6642);
        color: #fff;
        box-shadow: 0 4px 16px rgba(45,139,91,0.3);
      }
      .btn-host {
        background: linear-gradient(135deg, #e94560, #c4314f);
        color: #fff;
        box-shadow: 0 4px 16px rgba(233,69,96,0.3);
      }
      .not-logged {
        text-align: center;
        padding: 80px 24px;
        position: relative;
        z-index: 1;
      }
      .not-logged p { color: rgba(255,255,255,0.4); font-size: 15px; margin-bottom: 16px; }
      .not-logged a { color: #e94560; text-decoration: none; font-weight: 600; }
      .not-logged a:hover { text-decoration: underline; }
      .auth-btns { display: flex; gap: 10px; justify-content: center; flex-wrap: wrap; }
      .auth-btn {
        padding: 11px 28px;
        border-radius: 10px;
        font-size: 14px;
        font-weight: 700;
        font-family: inherit;
        cursor: pointer;
        text-decoration: none;
        transition: opacity 0.15s, transform 0.1s;
        display: inline-block;
      }
      .auth-btn:hover { opacity: 0.9; transform: translateY(-1px); }
      .auth-btn-primary { background: linear-gradient(135deg, #e94560, #c4314f); color: #fff; box-shadow: 0 4px 16px rgba(233,69,96,0.3); }
      .auth-btn-ghost { background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); color: rgba(255,255,255,0.7); }
      #msg { color: #ff6b6b; font-size: 13px; min-height: 20px; }
      .daily-badge {
        background: rgba(45,139,91,0.12);
        border: 1px solid rgba(45,139,91,0.25);
        color: #6bff91;
        padding: 8px 16px;
        border-radius: 10px;
        font-size: 13px;
        font-weight: 500;
      }
    </style>
  </head>
  <body>
    <header>
      <h1>CMD Casino</h1>
      <section>
        <a href="/shop"><img src="/shop.svg" alt="Shop"></a>
        <a href="/account"><img src="/accountIcon.svg" alt="Account"></a>
      </section>
    </header>

    <div id="logged-in" style="display:none">
      <div class="lobby">
        <div class="user-bar">
          Welkom, <strong id="username">–</strong>
          <span class="divider">|</span>
           <strong id="coins">–</strong>
        </div>
        <div id="daily-msg" class="daily-badge" style="display:none"></div>
        <div class="room-form">
          <input id="roomInput" type="text" inputmode="numeric" pattern="[0-9]*" placeholder="Kamer-nummer" maxlength="8" />
          <button class="btn btn-join" id="joinBtn">Join</button>
          <button class="btn btn-host" id="hostBtn">Host</button>
        </div>
        <div id="msg"></div>
      </div>
    </div>

    <div id="not-logged" class="not-logged" style="display:none">
      <p>Maak een account aan of log in om te spelen.</p>
      <div class="auth-btns">
        <a href="/login" class="auth-btn auth-btn-primary">Inloggen</a>
        <a href="/signup" class="auth-btn auth-btn-ghost">Registreren</a>
      </div>
    </div>

    <script>
      function loadUser() {
        const token = localStorage.getItem('token');
        if (!token) {
          const notLogged = document.getElementById('not-logged');
          const loggedIn = document.getElementById('logged-in');
          if (notLogged) notLogged.style.display = 'block';
          if (loggedIn) loggedIn.style.display = 'none';
          return;
        }
        fetch('/api/me', { headers: { Authorization: 'Bearer ' + token } })
          .then(r => r.ok ? r.json() : Promise.reject())
          .then(d => {
            const usernameEl = document.getElementById('username');
            const coinsEl = document.getElementById('coins');
            const loggedIn = document.getElementById('logged-in');
            if (usernameEl) usernameEl.textContent = d.username;
            if (coinsEl) coinsEl.textContent = (d.coins_amount ?? 0).toLocaleString('nl-NL');
            if (loggedIn) loggedIn.style.display = 'block';
          })
          .catch(() => { localStorage.removeItem('token'); location.reload(); });
      }

      loadUser();

      window.addEventListener('pageshow', (e) => { if (e.persisted) loadUser(); });

      {
        const dailyMsg = sessionStorage.getItem('dailyReward');
        if (dailyMsg) {
          const el = document.getElementById('daily-msg');
          if (el) { el.textContent = dailyMsg; el.style.display = 'block'; }
          sessionStorage.removeItem('dailyReward');
        }
      }

      function goToRoom(_host: boolean) {
        const roomInput = document.getElementById('roomInput') as HTMLInputElement;
        const msg = document.getElementById('msg') as HTMLElement;
        const room = roomInput?.value.trim();
        if (!room || !/^\d+$/.test(room)) { msg.textContent = 'Gebruik alleen cijfers voor het kamer-nummer.'; return; }
        msg.textContent = '';
        location.href = '/blackjack?room=' + encodeURIComponent(room);
      }

      document.getElementById('joinBtn')?.addEventListener('click', () => goToRoom(false));
      document.getElementById('hostBtn')?.addEventListener('click', () => goToRoom(true));
      document.getElementById('roomInput')?.addEventListener('keydown', (e: Event) => { if ((e as KeyboardEvent).key === 'Enter') goToRoom(false); });
    </script>
  </body>
</html>
