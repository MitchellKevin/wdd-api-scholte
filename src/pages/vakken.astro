<!doctype html>
<html lang="nl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Vakken — CMD Casino</title>
    <style is:global>
      @import url('https://fonts.googleapis.com/css2?family=Open+Sans:wght@400;500;600;700;800&display=swap');

      * { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        font-family: 'Open Sans', system-ui, sans-serif;
        min-height: 100vh;
        background-image: url('/cmd-bg.png');
        background-size: cover;
        background-position: center;
        background-attachment: fixed;
        color: rgba(255,255,255,0.85);
      }

      body::before {
        content: '';
        position: fixed;
        inset: 0;
        background: rgba(10,14,30,0.72);
        pointer-events: none;
      }

      header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 18px 32px;
        border-bottom: 2px solid #FFE600;
        background: rgba(10,14,30,0.85);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        position: sticky;
        top: 0;
        z-index: 10;
      }

      header h1 { font-size: 18px; font-weight: 800; color: #FFE600; letter-spacing: -0.3px; }

      .header-right { display: flex; align-items: center; gap: 20px; }

      .header-balance { font-size: 13px; font-weight: 700; color: rgba(255,255,255,0.4); }
      .header-balance strong { color: #FFE600; }

      header a {
        color: rgba(255,255,255,0.5);
        text-decoration: none;
        font-size: 13px;
        font-weight: 700;
        transition: color 0.15s;
      }
      header a:hover { color: #FFE600; }

      .page {
        max-width: 800px;
        margin: 0 auto;
        padding: 40px 24px 80px;
        position: relative;
        z-index: 1;
      }

      .page-header { margin-bottom: 28px; }
      .page-header h2 { font-size: 28px; font-weight: 800; letter-spacing: -0.5px; color: #FFE600; margin-bottom: 6px; }
      .page-header p { color: rgba(255,255,255,0.35); font-size: 14px; }

      /* Diploma */
      .diploma {
        display: none;
        background: rgba(45,139,91,0.15);
        border: 2px solid rgba(45,139,91,0.3);
        color: #6bff91;
        padding: 14px 18px;
        border-radius: 10px;
        margin-bottom: 28px;
        font-size: 14px;
        font-weight: 600;
        align-items: center;
        gap: 10px;
      }

      /* Progress */
      .progress-block {
        background: rgba(10,14,30,0.85);
        border: 2px solid rgba(255,255,255,0.08);
        border-radius: 14px;
        padding: 20px 22px;
        margin-bottom: 32px;
      }
      .progress-meta {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 12px;
        font-size: 13px;
        font-weight: 700;
        color: rgba(255,255,255,0.4);
      }
      .progress-meta span b { color: #FFE600; font-size: 15px; }
      .progress-bar {
        height: 8px;
        background: rgba(255,255,255,0.08);
        border-radius: 99px;
        overflow: hidden;
      }
      .progress-fill {
        height: 100%;
        background: #FFE600;
        border-radius: 99px;
        transition: width 0.5s ease;
        width: 0%;
      }

      /* Year section */
      .jaar-section { margin-bottom: 32px; }
      .jaar-label {
        font-size: 11px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: rgba(255,255,255,0.25);
        margin-bottom: 12px;
        padding-bottom: 10px;
        border-bottom: 1px solid rgba(255,255,255,0.06);
      }

      .courses-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
        gap: 12px;
      }

      /* Course card — same look as .pkg in shop */
      .course-card {
        background: rgba(10,14,30,0.88);
        border: 2px solid rgba(255,255,255,0.08);
        border-radius: 14px;
        padding: 20px 18px 16px;
        display: flex;
        flex-direction: column;
        gap: 14px;
        transition: border-color 0.2s, transform 0.2s;
      }
      .course-card:not(.owned):hover {
        border-color: #FFE600;
        transform: translateY(-3px);
      }
      .course-card.owned {
        border-color: rgba(107,255,145,0.3);
      }

      .card-top { display: flex; flex-direction: column; gap: 6px; }

      .course-name {
        font-size: 14px;
        font-weight: 700;
        color: rgba(255,255,255,0.9);
        line-height: 1.3;
      }

      .type-badge {
        display: inline-block;
        font-size: 10px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        padding: 3px 8px;
        border-radius: 5px;
        align-self: flex-start;
      }
      .type-vak     { background: rgba(100,130,255,0.18); color: #8aadff; }
      .type-project { background: rgba(255,160,0,0.18);   color: #ffb347; }
      .type-stage   { background: rgba(255,80,120,0.18);  color: #ff8aaa; }
      .type-minor   { background: rgba(160,80,255,0.18);  color: #c084fc; }

      .card-bottom {
        display: flex;
        justify-content: space-between;
        align-items: center;
      }

      .ec-label {
        font-size: 13px;
        color: rgba(255,255,255,0.35);
        font-weight: 600;
      }
      .ec-label b { color: #FFE600; font-size: 18px; font-weight: 800; }

      .buy-btn {
        padding: 9px 16px;
        border-radius: 8px;
        background: #FFE600;
        color: #111;
        border: none;
        font-size: 13px;
        font-weight: 800;
        font-family: inherit;
        cursor: pointer;
        transition: opacity 0.15s, transform 0.1s;
      }
      .buy-btn:hover { opacity: 0.85; transform: translateY(-1px); }
      .buy-btn:active { transform: translateY(0); }
      .buy-btn:disabled {
        background: rgba(255,255,255,0.08);
        color: rgba(255,255,255,0.25);
        cursor: default;
        transform: none;
      }

      .owned-tag {
        font-size: 13px;
        font-weight: 700;
        color: #6bff91;
      }

      #global-msg { margin-top: 16px; font-size: 13px; min-height: 18px; font-weight: 600; }
      .ok { color: #6bff91; }
      .err { color: #ff6b6b; }
    </style>
  </head>
  <body>
    <header>
      <h1>CMD Casino</h1>
      <div class="header-right">
        <div class="header-balance">Saldo: <strong id="hdr-balance">–</strong> EC</div>
        <a href="/">← Terug naar lobby</a>
      </div>
    </header>

    <div class="page">
      <div class="page-header">
        <h2>CMD Vakken</h2>
        <p>Koop vakken met EC-Punten. Rond alles af voor je diploma.</p>
      </div>

      <div class="diploma" id="diploma-banner">
        🎓 Gefeliciteerd — je hebt alle vakken gehaald en je diploma verdiend!
      </div>

      <div class="progress-block">
        <div class="progress-meta">
          <span id="progress-label">Laden…</span>
          <span><b id="progress-pct">–</b></span>
        </div>
        <div class="progress-bar">
          <div class="progress-fill" id="progress-fill"></div>
        </div>
      </div>

      <div id="jaren-container"></div>
      <p id="global-msg"></p>
    </div>

    <script>
      const TYPE_LABELS: Record<string, string> = {
        vak: 'Vak', project: 'Project', stage: 'Stage', minor: 'Minor'
      };

      let allCourses: any[] = [];
      let purchased: string[] = [];
      let balance = 0;
      let totalEc = 0;

      async function load() {
        const token = localStorage.getItem('token');
        if (!token) { location.href = '/login'; return; }

        const [coursesRes, meRes] = await Promise.all([
          fetch('/api/courses.json', { headers: { Authorization: 'Bearer ' + token } }),
          fetch('/api/me',           { headers: { Authorization: 'Bearer ' + token } }),
        ]);

        if (!coursesRes.ok) { location.href = '/login'; return; }

        const data = await coursesRes.json();
        const me   = meRes.ok ? await meRes.json() : {};

        allCourses = data.courses;
        purchased  = data.purchased ?? [];
        balance    = me.coins_amount ?? 0;
        totalEc    = data.totalEc;

        render();
      }

      function render() {
        (document.getElementById('hdr-balance') as HTMLElement).textContent =
          balance.toLocaleString('nl-NL');

        const earnedEc = allCourses
          .filter(c => purchased.includes(c.id))
          .reduce((s: number, c: any) => s + c.ec, 0);
        const pct = totalEc > 0 ? Math.round((earnedEc / totalEc) * 100) : 0;

        (document.getElementById('progress-label') as HTMLElement).textContent =
          `${earnedEc} / ${totalEc} EC behaald`;
        (document.getElementById('progress-pct') as HTMLElement).textContent = `${pct}%`;
        (document.getElementById('progress-fill') as HTMLElement).style.width = pct + '%';

        const diploma = document.getElementById('diploma-banner') as HTMLElement;
        diploma.style.display =
          purchased.length === allCourses.length && allCourses.length > 0 ? 'flex' : 'none';

        const jaren: Record<number, any[]> = {};
        for (const c of allCourses) {
          if (!jaren[c.jaar]) jaren[c.jaar] = [];
          jaren[c.jaar].push(c);
        }

        const container = document.getElementById('jaren-container') as HTMLElement;
        container.innerHTML = '';

        for (const jaar of Object.keys(jaren).map(Number).sort()) {
          const section = document.createElement('div');
          section.className = 'jaar-section';

          const label = document.createElement('div');
          label.className = 'jaar-label';
          label.textContent = `Jaar ${jaar}`;
          section.appendChild(label);

          const grid = document.createElement('div');
          grid.className = 'courses-grid';
          for (const course of jaren[jaar]) grid.appendChild(buildCard(course));

          section.appendChild(grid);
          container.appendChild(section);
        }
      }

      function buildCard(course: any) {
        const owned = purchased.includes(course.id);
        const card  = document.createElement('div');
        card.className = 'course-card' + (owned ? ' owned' : '');

        // Top: name + type badge
        const top = document.createElement('div');
        top.className = 'card-top';

        const name = document.createElement('div');
        name.className = 'course-name';
        name.textContent = course.name;

        const badge = document.createElement('span');
        badge.className = `type-badge type-${course.type}`;
        badge.textContent = TYPE_LABELS[course.type] ?? course.type;

        top.appendChild(name);
        top.appendChild(badge);

        // Bottom: EC + button/tag
        const bottom = document.createElement('div');
        bottom.className = 'card-bottom';

        const ec = document.createElement('div');
        ec.className = 'ec-label';
        ec.innerHTML = `<b>${course.ec}</b> EC`;

        if (owned) {
          const tag = document.createElement('span');
          tag.className = 'owned-tag';
          tag.textContent = '✓ Gehaald';
          bottom.appendChild(ec);
          bottom.appendChild(tag);
        } else {
          const btn = document.createElement('button');
          btn.className = 'buy-btn';
          btn.textContent = 'Kopen';
          btn.disabled = balance < course.ec;
          btn.addEventListener('click', () => buyClick(course, btn));
          bottom.appendChild(ec);
          bottom.appendChild(btn);
        }

        card.appendChild(top);
        card.appendChild(bottom);
        return card;
      }

      async function buyClick(course: any, btn: HTMLButtonElement) {
        const token = localStorage.getItem('token');
        const msg   = document.getElementById('global-msg') as HTMLElement;
        btn.disabled = true; btn.textContent = 'Bezig…';
        msg.textContent = ''; msg.className = '';

        try {
          const res = await fetch('/api/buy-course', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', Authorization: 'Bearer ' + token },
            body: JSON.stringify({ courseId: course.id }),
          });
          const data = await res.json();
          if (res.ok) {
            purchased.push(course.id);
            balance -= course.ec;
            render();
          } else {
            msg.className = 'err';
            msg.textContent = data.error || 'Kopen mislukt';
            btn.disabled = false; btn.textContent = 'Kopen';
          }
        } catch {
          msg.className = 'err'; msg.textContent = 'Netwerkfout';
          btn.disabled = false; btn.textContent = 'Kopen';
        }
      }

      load();
    </script>
  </body>
</html>
