<!doctype html>
<html lang="nl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Registreren — CMD Casino</title>
    <style>
      @import url('https://fonts.googleapis.com/css2?family=Open+Sans:wght@400;500;600;700;800&display=swap');
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        font-family: 'Open Sans', system-ui, sans-serif;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 24px;
        background-image: url('/cmd-bg.png');
        background-size: cover;
        background-position: center;
      }
      body::before {
        content: '';
        position: fixed;
        inset: 0;
        background: rgba(10,14,30,0.72);
        pointer-events: none;
      }
      .card {
        width: 100%;
        max-width: 400px;
        background: rgba(10, 14, 30, 0.9);
        backdrop-filter: blur(24px);
        -webkit-backdrop-filter: blur(24px);
        border: 2px solid #FFE600;
        border-radius: 16px;
        padding: 40px 36px;
        box-shadow: 0 24px 64px rgba(0,0,0,0.6);
        animation: fadeUp 0.4s ease both;
      }
      .card-icon { font-size: 36px; text-align: center; display: block; margin-bottom: 10px; }
      h2 {
        font-size: 26px;
        font-weight: 800;
        text-align: center;
        margin-bottom: 28px;
        letter-spacing: -0.5px;
        color: #FFE600;
      }
      label {
        display: block;
        color: rgba(255,255,255,0.5);
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        margin-bottom: 6px;
      }
      input {
        width: 100%;
        padding: 11px 14px;
        background: rgba(255,255,255,0.05);
        border: 2px solid rgba(255,255,255,0.12);
        border-radius: 8px;
        color: rgba(255,255,255,0.9);
        font-size: 15px;
        font-family: inherit;
        font-weight: 600;
        margin-bottom: 6px;
        transition: border-color 0.15s;
      }
      input:focus { outline: none; border-color: #FFE600; }
      input::placeholder { color: rgba(255,255,255,0.2); }
      .hint {
        color: rgba(255,255,255,0.25);
        font-size: 12px;
        margin-bottom: 18px;
      }
      button {
        width: 100%;
        padding: 13px;
        background: #FFE600;
        border: none;
        border-radius: 8px;
        color: #111;
        font-size: 15px;
        font-weight: 800;
        font-family: inherit;
        cursor: pointer;
        transition: opacity 0.15s, transform 0.1s;
      }
      button:hover { opacity: 0.85; transform: translateY(-1px); }
      button:active { transform: translateY(0); }
      button:disabled { opacity: 0.5; cursor: default; transform: none; }
      #msg { margin-top: 14px; text-align: center; font-size: 14px; min-height: 20px; }
      .err { color: #ff6b6b; } .ok { color: #6bff91; }
      .footer-link {
        text-align: center;
        margin-top: 22px;
        color: rgba(255,255,255,0.3);
        font-size: 13px;
      }
      .footer-link a { color: #FFE600; text-decoration: none; font-weight: 700; }
      .footer-link a:hover { text-decoration: underline; }
      @keyframes fadeUp {
        from { opacity: 0; transform: translateY(16px); }
        to   { opacity: 1; transform: translateY(0); }
      }
    </style>
  </head>
  <body>
    <div class="card">
      <span class="card-icon">🃏</span>
      <h2>Registreren</h2>
      <label for="username">Gebruikersnaam</label>
      <input id="username" type="text" placeholder="jouw_naam" autocomplete="username" />
      <p class="hint">3–20 tekens, alleen letters, cijfers en _</p>
      <label for="password">Wachtwoord</label>
      <input id="password" type="password" placeholder="••••••••" autocomplete="new-password" />
      <p class="hint">Minimaal 6 tekens</p>
      <button id="btn">Account aanmaken</button>
      <p id="msg"></p>
      <div class="footer-link">Al een account? <a href="/login">Inloggen</a></div>
    </div>
    <script>
      const btn = document.getElementById('btn') as HTMLButtonElement | null;
      const msg = document.getElementById('msg') as HTMLElement | null;
      async function signup() {
        if (!btn || !msg) return;
        btn.disabled = true; btn.textContent = 'Bezig...';
        msg.textContent = ''; msg.className = '';
        const username = (document.getElementById('username') as HTMLInputElement).value.trim();
        const password = (document.getElementById('password') as HTMLInputElement).value;
        try {
          const res = await fetch('/api/signup', {
            method: 'POST', credentials: 'include',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ username, password })
          });
          const data = await res.json();
          if (res.ok) {
            msg.className = 'ok'; msg.textContent = 'Account aangemaakt! Je wordt doorgestuurd...';
            setTimeout(() => { location.href = '/login'; }, 800);
          } else {
            msg.className = 'err'; msg.textContent = data.message || 'Registratie mislukt';
          }
        } catch {
          msg.className = 'err'; msg.textContent = 'Netwerkfout, probeer opnieuw';
        } finally {
          btn.disabled = false; btn.textContent = 'Account aanmaken';
        }
      }
      btn?.addEventListener('click', signup);
      document.addEventListener('keydown', e => { if (e.key === 'Enter') signup(); });
    </script>
  </body>
</html>
