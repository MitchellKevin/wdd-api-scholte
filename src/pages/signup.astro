---
import '../styles/signup.css';
---
<!doctype html>
<html lang="nl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Registreren — CMD Casino</title>
  </head>
  <body>
    <div class="card">
      <span class="card-icon">🃏</span>
      <h2>Registreren</h2>
      <label for="username">Gebruikersnaam</label>
      <input id="username" type="text" placeholder="jouw_naam" autocomplete="username" />
      <p class="hint">3–20 tekens, alleen letters, cijfers en _</p>
      <label for="password">Wachtwoord</label>
      <input id="password" type="password" placeholder="••••••••" autocomplete="new-password" />
      <p class="hint">Minimaal 6 tekens</p>
      <button id="btn">Account aanmaken</button>
      <p id="msg"></p>
      <div class="footer-link">Al een account? <a href="/login">Inloggen</a></div>
    </div>
    <script src="../scripts/signup.js"></script>
  </body>
</html>
