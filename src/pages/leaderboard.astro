<!doctype html>
<html lang="nl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Leaderboard — Blackjack</title>
    <style>
      @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap');

      * { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        font-family: 'Inter', system-ui, sans-serif;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 24px;
        background-image: url('./bg.png');
        background-size: cover;
        background-position: center;
      }

      body::before {
        content: '';
        position: fixed;
        inset: 0;
        background: radial-gradient(ellipse 80% 60% at 50% 0%, rgba(255, 215, 0, 0.08) 0%, transparent 70%);
        pointer-events: none;
      }

      .card {
        width: 100%;
        max-width: 540px;
        background: rgba(10, 14, 30, 0.75);
        backdrop-filter: blur(24px);
        -webkit-backdrop-filter: blur(24px);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 24px;
        padding: 40px 36px 32px;
        box-shadow:
          0 0 0 1px rgba(255, 215, 0, 0.04),
          0 24px 64px rgba(0, 0, 0, 0.6),
          inset 0 1px 0 rgba(255, 255, 255, 0.06);
      }

      .header {
        text-align: center;
        margin-bottom: 32px;
      }

      .trophy-icon {
        font-size: 40px;
        display: block;
        margin-bottom: 10px;
        filter: drop-shadow(0 0 12px rgba(255, 215, 0, 0.6));
      }

      h2 {
        font-size: 26px;
        font-weight: 800;
        background: linear-gradient(135deg, #fff 0%, #ffd700 60%, #ffaa00 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        letter-spacing: -0.5px;
      }

      .subtitle {
        color: rgba(255,255,255,0.35);
        font-size: 13px;
        margin-top: 6px;
        letter-spacing: 0.02em;
      }

      .col-headers {
        display: grid;
        grid-template-columns: 48px 1fr auto;
        gap: 12px;
        padding: 0 12px 10px;
        color: rgba(255,255,255,0.25);
        font-size: 11px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        border-bottom: 1px solid rgba(255,255,255,0.06);
        margin-bottom: 8px;
      }

      .row {
        display: grid;
        grid-template-columns: 48px 1fr auto;
        align-items: center;
        gap: 12px;
        padding: 10px 12px;
        border-radius: 12px;
        margin-bottom: 4px;
        transition: background 0.15s ease, transform 0.15s ease;
        animation: fadeSlideIn 0.4s ease both;
      }

      .row:hover {
        background: rgba(255,255,255,0.04);
        transform: translateX(2px);
      }

      .row.rank-1 { background: linear-gradient(90deg, rgba(255,215,0,0.12) 0%, transparent 100%); border: 1px solid rgba(255,215,0,0.15); }
      .row.rank-2 { background: linear-gradient(90deg, rgba(192,192,192,0.08) 0%, transparent 100%); border: 1px solid rgba(192,192,192,0.1); }
      .row.rank-3 { background: linear-gradient(90deg, rgba(205,127,50,0.08) 0%, transparent 100%); border: 1px solid rgba(205,127,50,0.1); }

      .rank-badge {
        width: 36px;
        height: 36px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 13px;
        background: rgba(255,255,255,0.05);
        color: rgba(255,255,255,0.4);
      }

      .rank-badge.medal { font-size: 20px; background: transparent; }

      .player {
        display: flex;
        align-items: center;
        gap: 10px;
        min-width: 0;
      }

      .avatar {
        width: 34px;
        height: 34px;
        border-radius: 50%;
        background: linear-gradient(135deg, #1a2a4a, #0f3460);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 13px;
        font-weight: 700;
        color: rgba(255,255,255,0.7);
        flex-shrink: 0;
        border: 1px solid rgba(255,255,255,0.08);
      }

      .row.rank-1 .avatar { background: linear-gradient(135deg, #7a5c00, #ffd700); color: #000; border-color: rgba(255,215,0,0.4); }
      .row.rank-2 .avatar { background: linear-gradient(135deg, #606060, #c0c0c0); color: #000; border-color: rgba(192,192,192,0.4); }
      .row.rank-3 .avatar { background: linear-gradient(135deg, #6b3a1a, #cd7f32); color: #000; border-color: rgba(205,127,50,0.4); }

      .username {
        color: rgba(255,255,255,0.85);
        font-size: 14px;
        font-weight: 600;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }

      .username.me {
        color: #ffd700;
        text-shadow: 0 0 12px rgba(255,215,0,0.4);
      }

      .you-badge {
        font-size: 10px;
        font-weight: 600;
        background: rgba(255,215,0,0.15);
        color: #ffd700;
        border: 1px solid rgba(255,215,0,0.3);
        border-radius: 6px;
        padding: 1px 6px;
        letter-spacing: 0.05em;
        flex-shrink: 0;
      }

      .coins-wrap {
        display: flex;
        align-items: center;
        gap: 5px;
        white-space: nowrap;
      }

      .coin-icon { font-size: 14px; }

      .coins {
        color: #ffd700;
        font-weight: 700;
        font-size: 14px;
        font-variant-numeric: tabular-nums;
      }

      .row.rank-1 .coins { font-size: 15px; text-shadow: 0 0 10px rgba(255,215,0,0.5); }

      #loading {
        text-align: center;
        color: rgba(255,255,255,0.3);
        padding: 32px 0;
        font-size: 14px;
      }

      .spinner {
        width: 28px;
        height: 28px;
        border: 2px solid rgba(255,255,255,0.08);
        border-top-color: #ffd700;
        border-radius: 50%;
        animation: spin 0.7s linear infinite;
        margin: 0 auto 12px;
      }

      #error {
        display: none;
        text-align: center;
        color: #ff6b6b;
        padding: 24px 0;
        font-size: 14px;
      }

      .back {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        margin-top: 20px;
        color: rgba(255,255,255,0.3);
        font-size: 13px;
        text-decoration: none;
        transition: color 0.15s;
        font-weight: 500;
      }

      .back:hover { color: rgba(255,255,255,0.7); }

      @keyframes spin { to { transform: rotate(360deg); } }

      @keyframes fadeSlideIn {
        from { opacity: 0; transform: translateY(8px); }
        to   { opacity: 1; transform: translateY(0); }
      }
    </style>
  </head>
  <body>
    <div class="card">
      <div class="header">
        <span class="trophy-icon">🏆</span>
        <h2>Leaderboard</h2>
        <p class="subtitle">Top 10 spelers met de meeste coins</p>
      </div>

      <div class="col-headers">
        <span style="text-align:center">#</span>
        <span>Speler</span>
        <span>Coins</span>
      </div>

      <div id="loading">
        <div class="spinner"></div>
        Laden…
      </div>
      <div id="error">Kon leaderboard niet laden.</div>
      <div id="list"></div>
    </div>

    <a href="/" class="back">← Terug naar lobby</a>

    <script>
      async function loadLeaderboard() {
        const token = localStorage.getItem('token');
        let myUsername = null;

        if (token) {
          try {
            const me = await fetch('/api/me', { headers: { Authorization: 'Bearer ' + token } });
            if (me.ok) myUsername = (await me.json()).username;
          } catch {}
        }

        try {
          const res = await fetch('/api/leaderboard.json');
          if (!res.ok) throw new Error();
          const { top } = await res.json();

          document.getElementById('loading').style.display = 'none';
          const list = document.getElementById('list');

          const medals: Record<number, string> = { 1: '🥇', 2: '🥈', 3: '🥉' };

          top.forEach((p: { rank: number; username: string; coins_amount: number }, i: number) => {
            const row = document.createElement('div');
            row.className = 'row' + (p.rank <= 3 ? ' rank-' + p.rank : '');
            row.style.animationDelay = (i * 60) + 'ms';

            const rankBadge = document.createElement('div');
            rankBadge.className = 'rank-badge' + (medals[p.rank] ? ' medal' : '');
            rankBadge.textContent = medals[p.rank] ?? String(p.rank);

            const player = document.createElement('div');
            player.className = 'player';

            const avatar = document.createElement('div');
            avatar.className = 'avatar';
            avatar.textContent = p.username.slice(0, 2).toUpperCase();

            const nameWrap = document.createElement('div');
            nameWrap.style.cssText = 'display:flex;align-items:center;gap:6px;min-width:0';

            const nameEl = document.createElement('span');
            nameEl.className = 'username' + (p.username === myUsername ? ' me' : '');
            nameEl.textContent = p.username;

            nameWrap.appendChild(nameEl);

            if (p.username === myUsername) {
              const badge = document.createElement('span');
              badge.className = 'you-badge';
              badge.textContent = 'JIJ';
              nameWrap.appendChild(badge);
            }

            player.appendChild(avatar);
            player.appendChild(nameWrap);

            const coinsWrap = document.createElement('div');
            coinsWrap.className = 'coins-wrap';

            const coinIcon = document.createElement('span');
            coinIcon.className = 'coin-icon';
            coinIcon.textContent = '🪙';

            const coinsEl = document.createElement('span');
            coinsEl.className = 'coins';
            coinsEl.textContent = p.coins_amount.toLocaleString('nl-NL');

            coinsWrap.appendChild(coinIcon);
            coinsWrap.appendChild(coinsEl);

            row.appendChild(rankBadge);
            row.appendChild(player);
            row.appendChild(coinsWrap);
            list.appendChild(row);
          });

          if (top.length === 0) {
            list.textContent = 'Nog geen spelers.';
            list.style.cssText = 'text-align:center;color:rgba(255,255,255,0.3);padding:32px 0;font-size:14px';
          }
        } catch {
          document.getElementById('loading').style.display = 'none';
          document.getElementById('error').style.display = 'block';
        }
      }

      loadLeaderboard();
    </script>
  </body>
</html>
