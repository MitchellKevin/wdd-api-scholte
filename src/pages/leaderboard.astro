<!doctype html>
<html lang="nl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Leaderboard — CMD Casino</title>
    <style>
      @import url('https://fonts.googleapis.com/css2?family=Open+Sans:wght@400;500;600;700;800&display=swap');

      * { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        font-family: 'Open Sans', system-ui, sans-serif;
        min-height: 100vh;
        background-image: url('/cmd-bg.png');
        background-size: cover;
        background-position: center;
        background-attachment: fixed;
        color: rgba(255,255,255,0.85);
      }

      body::before {
        content: '';
        position: fixed;
        inset: 0;
        background: rgba(10,14,30,0.72);
        pointer-events: none;
      }

      header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 18px 32px;
        border-bottom: 2px solid #FFE600;
        background: rgba(10,14,30,0.85);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        position: sticky;
        top: 0;
        z-index: 10;
      }

      header h1 {
        font-size: 18px;
        font-weight: 800;
        color: #FFE600;
        letter-spacing: -0.3px;
      }

      header a {
        color: rgba(255,255,255,0.5);
        text-decoration: none;
        font-size: 13px;
        font-weight: 700;
        transition: color 0.15s;
      }
      header a:hover { color: #FFE600; }

      .page {
        max-width: 600px;
        margin: 0 auto;
        padding: 40px 24px 80px;
        position: relative;
        z-index: 1;
      }

      .page-header { margin-bottom: 28px; }
      .page-header h2 {
        font-size: 28px;
        font-weight: 800;
        letter-spacing: -0.5px;
        color: #FFE600;
        margin-bottom: 6px;
      }
      .page-header p { color: rgba(255,255,255,0.35); font-size: 14px; }

      .col-headers {
        display: grid;
        grid-template-columns: 48px 1fr auto;
        gap: 12px;
        padding: 0 12px 10px;
        color: rgba(255,255,255,0.25);
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        border-bottom: 1px solid rgba(255,255,255,0.08);
        margin-bottom: 8px;
      }

      .row {
        display: grid;
        grid-template-columns: 48px 1fr auto;
        align-items: center;
        gap: 12px;
        padding: 10px 12px;
        border-radius: 10px;
        margin-bottom: 4px;
        transition: background 0.15s ease, transform 0.15s ease;
        animation: fadeSlideIn 0.4s ease both;
      }

      .row:hover {
        background: rgba(255,255,255,0.04);
        transform: translateX(2px);
      }

      .row.rank-1 { background: linear-gradient(90deg, rgba(255,215,0,0.12) 0%, transparent 100%); border: 1px solid rgba(255,215,0,0.2); }
      .row.rank-2 { background: linear-gradient(90deg, rgba(192,192,192,0.08) 0%, transparent 100%); border: 1px solid rgba(192,192,192,0.1); }
      .row.rank-3 { background: linear-gradient(90deg, rgba(205,127,50,0.08) 0%, transparent 100%); border: 1px solid rgba(205,127,50,0.1); }

      .rank-badge {
        width: 36px;
        height: 36px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 800;
        font-size: 13px;
        background: rgba(255,255,255,0.05);
        color: rgba(255,255,255,0.4);
      }

      .rank-badge.medal { font-size: 20px; background: transparent; }

      .player {
        display: flex;
        align-items: center;
        gap: 10px;
        min-width: 0;
      }

      .avatar {
        width: 34px;
        height: 34px;
        border-radius: 50%;
        background: linear-gradient(135deg, #1a2a4a, #0f3460);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 13px;
        font-weight: 800;
        color: rgba(255,255,255,0.7);
        flex-shrink: 0;
        border: 2px solid rgba(255,255,255,0.08);
      }

      .row.rank-1 .avatar { background: linear-gradient(135deg, #7a5c00, #ffd700); color: #000; border-color: rgba(255,215,0,0.4); }
      .row.rank-2 .avatar { background: linear-gradient(135deg, #606060, #c0c0c0); color: #000; border-color: rgba(192,192,192,0.4); }
      .row.rank-3 .avatar { background: linear-gradient(135deg, #6b3a1a, #cd7f32); color: #000; border-color: rgba(205,127,50,0.4); }

      .username {
        color: rgba(255,255,255,0.85);
        font-size: 14px;
        font-weight: 700;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }

      .username.me { color: #FFE600; }

      .you-badge {
        font-size: 10px;
        font-weight: 800;
        background: #FFE600;
        color: #111;
        border-radius: 5px;
        padding: 1px 6px;
        letter-spacing: 0.05em;
        flex-shrink: 0;
      }

      .coins-wrap {
        display: flex;
        align-items: center;
        gap: 5px;
        white-space: nowrap;
      }

      .coin-icon { font-size: 14px; }

      .coins {
        color: #FFE600;
        font-weight: 800;
        font-size: 14px;
        font-variant-numeric: tabular-nums;
      }

      #loading {
        text-align: center;
        color: rgba(255,255,255,0.3);
        padding: 32px 0;
        font-size: 14px;
      }

      .spinner {
        width: 28px;
        height: 28px;
        border: 3px solid rgba(255,255,255,0.08);
        border-top-color: #FFE600;
        border-radius: 50%;
        animation: spin 0.7s linear infinite;
        margin: 0 auto 12px;
      }

      #error {
        display: none;
        text-align: center;
        color: #ff6b6b;
        padding: 24px 0;
        font-size: 14px;
      }

      @keyframes spin { to { transform: rotate(360deg); } }

      @keyframes fadeSlideIn {
        from { opacity: 0; transform: translateY(8px); }
        to   { opacity: 1; transform: translateY(0); }
      }
    </style>
  </head>
  <body>
    <header>
      <h1>CMD Casino</h1>
      <a href="/">← Terug naar lobby</a>
    </header>

    <div class="page">
      <div class="page-header">
        <h2>🏆 Leaderboard</h2>
        <p>Top 10 spelers met de meeste EC-Punten</p>
      </div>

      <div class="col-headers">
        <span style="text-align:center">#</span>
        <span>Speler</span>
        <span>EC-Punten</span>
      </div>

      <div id="loading">
        <div class="spinner"></div>
        Laden…
      </div>
      <div id="error">Kon leaderboard niet laden.</div>
      <div id="list"></div>
    </div>

    <script>
      async function loadLeaderboard() {
        const token = localStorage.getItem('token');
        let myUsername = null;

        if (token) {
          try {
            const me = await fetch('/api/me', { headers: { Authorization: 'Bearer ' + token } });
            if (me.ok) myUsername = (await me.json()).username;
          } catch {}
        }

        try {
          const res = await fetch('/api/leaderboard.json');
          if (!res.ok) throw new Error();
          const { top } = await res.json();

          document.getElementById('loading').style.display = 'none';
          const list = document.getElementById('list');

          const medals: Record<number, string> = { 1: '🥇', 2: '🥈', 3: '🥉' };

          top.forEach((p: { rank: number; username: string; coins_amount: number }, i: number) => {
            const row = document.createElement('div');
            row.className = 'row' + (p.rank <= 3 ? ' rank-' + p.rank : '');
            row.style.animationDelay = (i * 60) + 'ms';

            const rankBadge = document.createElement('div');
            rankBadge.className = 'rank-badge' + (medals[p.rank] ? ' medal' : '');
            rankBadge.textContent = medals[p.rank] ?? String(p.rank);

            const player = document.createElement('div');
            player.className = 'player';

            const avatar = document.createElement('div');
            avatar.className = 'avatar';
            avatar.textContent = p.username.slice(0, 2).toUpperCase();

            const nameWrap = document.createElement('div');
            nameWrap.style.cssText = 'display:flex;align-items:center;gap:6px;min-width:0';

            const nameEl = document.createElement('span');
            nameEl.className = 'username' + (p.username === myUsername ? ' me' : '');
            nameEl.textContent = p.username;

            nameWrap.appendChild(nameEl);

            if (p.username === myUsername) {
              const badge = document.createElement('span');
              badge.className = 'you-badge';
              badge.textContent = 'JIJ';
              nameWrap.appendChild(badge);
            }

            player.appendChild(avatar);
            player.appendChild(nameWrap);

            const coinsWrap = document.createElement('div');
            coinsWrap.className = 'coins-wrap';

            const coinIcon = document.createElement('span');
            coinIcon.className = 'coin-icon';
            coinIcon.textContent = '🪙';

            const coinsEl = document.createElement('span');
            coinsEl.className = 'coins';
            coinsEl.textContent = p.coins_amount.toLocaleString('nl-NL');

            coinsWrap.appendChild(coinIcon);
            coinsWrap.appendChild(coinsEl);

            row.appendChild(rankBadge);
            row.appendChild(player);
            row.appendChild(coinsWrap);
            list.appendChild(row);
          });

          if (top.length === 0) {
            list.textContent = 'Nog geen spelers.';
            list.style.cssText = 'text-align:center;color:rgba(255,255,255,0.3);padding:32px 0;font-size:14px';
          }
        } catch {
          document.getElementById('loading').style.display = 'none';
          document.getElementById('error').style.display = 'block';
        }
      }

      loadLeaderboard();
    </script>
  </body>
</html>
