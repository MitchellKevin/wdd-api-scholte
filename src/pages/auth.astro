<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Auth Demo</title>
    <link rel="stylesheet" href="/index.css">
  </head>
  <body>
    <main style="padding:2rem;">
      <h1>Auth0 Demo (Popup Login)</h1>
      <div id="app">
        <div id="loading">Loading...</div>
        <div id="logged-out" style="display:none">
          <button id="login">Log in</button>
        </div>
        <div id="logged-in" style="display:none">
          <div id="profile"></div>
          <button id="logout">Log out</button>
        </div>
      </div>
    </main>
    <script type="module">
      import createAuth0Client from '@auth0/auth0-spa-js';

      const domain = import.meta.env.VITE_AUTH0_DOMAIN;
      const clientId = import.meta.env.VITE_AUTH0_CLIENT_ID;

      const loading = document.getElementById('loading');
      const loggedOut = document.getElementById('logged-out');
      const loggedIn = document.getElementById('logged-in');
      const loginBtn = document.getElementById('login');
      const logoutBtn = document.getElementById('logout');
      const profileEl = document.getElementById('profile');

      let auth0 = null;

      async function init(){
        try{
          if(!domain || !clientId || domain.includes('your-auth0-domain')){
            loading.textContent = 'Missing or placeholder Auth0 config. Update .env.local with your domain and client id.';
            return;
          }

          auth0 = await createAuth0Client({
            domain,
            client_id: clientId,
            authorizationParams: { redirect_uri: window.location.origin }
          });

          // If returning from redirect, handle it first
          if(window.location.search.includes('code=') && window.location.search.includes('state=')){
            try{
              await auth0.handleRedirectCallback();
              window.history.replaceState({}, document.title, window.location.pathname);
            }catch(e){
              console.error('Redirect handling error', e);
              loading.textContent = 'Error handling login redirect: ' + (e.message || e);
              return;
            }
          }

          // Attempt silent auth
          try{ await auth0.getTokenSilently(); }catch(e){ /* ignore */ }

          const isAuthenticated = await auth0.isAuthenticated();
          loading.style.display = 'none';
          if(isAuthenticated){ await showProfile(); } else { loggedOut.style.display = 'block'; }
        }catch(err){
          console.error('Auth init error', err);
          loading.textContent = 'Initialization error: ' + (err.message || err);
        }
      }

      async function popupLogin(){
        try{
          loading.style.display = 'block';
          loggedOut.style.display = 'none';
          await auth0.loginWithPopup();
          await showProfile();
          loading.style.display = 'none';
        }catch(e){
          console.error('Popup login failed, falling back to redirect', e);
          await auth0.loginWithRedirect();
        }
      }

      async function showProfile(){
        try{
          const user = await auth0.getUser();
          profileEl.innerHTML = `<pre style="white-space:pre-wrap">${JSON.stringify(user,null,2)}</pre>`;
          loggedIn.style.display = 'block';
          loggedOut.style.display = 'none';
        }catch(e){
          console.error('Profile error', e);
          loading.textContent = 'Failed to load profile: ' + (e.message || e);
        }
      }

      loginBtn.addEventListener('click', ()=> auth0 && popupLogin());
      logoutBtn.addEventListener('click', ()=> auth0 && auth0.logout({ logoutParams: { returnTo: window.location.origin }}));

      init();
    </script>
  </body>
</html>
